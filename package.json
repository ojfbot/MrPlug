{
  "name": "mrplug",
  "version": "0.1.0",
  "description": "AI-powered browser plugin for real-time UI/UX feedback and modification",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/inject-env.js && tsc && vite build",
    "build:prod": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "e2e": "pnpm build && playwright test",
    "lint": "eslint . --ext ts,tsx",
    "type-check": "tsc --noEmit",
    "package": "pnpm build && web-ext build -s dist -a web-ext-artifacts",
    "start": "pnpm build && python3 -m http.server 8080 --directory ."
  },
  "keywords": [
    "browser-extension",
    "ai",
    "langchain",
    "ui-feedback",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.18.1",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "dependencies": {
    "@carbon/react": "^1.64.0",
    "@langchain/anthropic": "^0.3.13",
    "@langchain/core": "^0.3.79",
    "@langchain/openai": "^0.3.0",
    "@octokit/rest": "^21.0.0",
    "langchain": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "webextension-polyfill": "^0.12.0",
    "zod": "^3.23.0"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=2.80.0"
    }
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/webextension-polyfill": "0.12.4",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "happy-dom": "^20.8.9",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0",
    "web-ext": "^8.2.0"
  }
}
