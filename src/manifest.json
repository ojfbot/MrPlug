{
  "manifest_version": 3,
  "name": "MrPlug - AI UI Feedback Assistant",
  "version": "0.1.0",
  "description": "AI-powered browser plugin for real-time UI/UX feedback and modification",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["src/content/index.tsx"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "48": "icons/icon-48.svg",
      "128": "icons/icon-128.svg"
    }
  },
  "options_page": "src/options/index.html",
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  },
  "commands": {
    "trigger-feedback": {
      "suggested_key": {
        "default": "Alt+Shift+F",
        "mac": "MacCtrl+Shift+F"
      },
      "description": "Trigger UI feedback interface (or use fn-F1 + click)"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
